{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(css|js|images|fonts)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/finance/:symbol",
      "destination": "https://query1.finance.yahoo.com/v8/finance/chart/:symbol"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/article/:slug",
      "destination": "/article.html?slug=:slug"
    },
    {
      "source": "/category/:slug",
      "destination": "/category.html?slug=:slug"
    }
  ]
}
