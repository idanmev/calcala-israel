{
    "cleanUrls": false,
    "rewrites": [
        {
            "source": "/",
            "destination": "/index.html"
        },
        {
            "source": "/article/**",
            "destination": "/article.html"
        },
        {
            "source": "/article",
            "destination": "/article.html"
        },
        {
            "source": "/category/**",
            "destination": "/category.html"
        },
        {
            "source": "/category",
            "destination": "/category.html"
        },
        {
            "source": "/admin",
            "destination": "/admin/dashboard.html"
        },
        {
            "source": "/admin/dashboard",
            "destination": "/admin/dashboard.html"
        },
        {
            "source": "/admin/login",
            "destination": "/admin/login.html"
        },
        {
            "source": "/admin/article-edit",
            "destination": "/admin/article-edit.html"
        },
        {
            "source": "/admin/categories",
            "destination": "/admin/categories.html"
        },
        {
            "source": "/admin/quiz-config",
            "destination": "/admin/quiz-config.html"
        },
        {
            "source": "/admin/leads",
            "destination": "/admin/leads.html"
        },
        {
            "source": "/admin/lead-forms",
            "destination": "/admin/lead-forms.html"
        }
    ]
}